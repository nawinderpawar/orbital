{
  "name": "orbital",
  "displayName": "Orbital",
  "description": "Track everything in your orbit — monitor parallel workstreams across all your repos.",
  "version": "0.1.0",
  "publisher": "orbital-dev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "workstream",
    "dashboard",
    "repos",
    "monitor"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orbital",
          "title": "Orbital",
          "icon": "media/orbital.svg"
        }
      ]
    },
    "views": {
      "orbital": [
        {
          "id": "orbital.repoTree",
          "name": "Repositories"
        }
      ]
    },
    "commands": [
      {
        "command": "orbital.addRepo",
        "title": "Orbital: Add Repository",
        "icon": "$(add)"
      },
      {
        "command": "orbital.removeRepo",
        "title": "Orbital: Remove Repository",
        "icon": "$(trash)"
      },
      {
        "command": "orbital.editNotes",
        "title": "Orbital: Edit Notes",
        "icon": "$(edit)"
      },
      {
        "command": "orbital.refresh",
        "title": "Orbital: Refresh All",
        "icon": "$(refresh)"
      },
      {
        "command": "orbital.openDashboard",
        "title": "Orbital: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "orbital.openRepoFolder",
        "title": "Orbital: Open in New Window",
        "icon": "$(folder-opened)"
      },
      {
        "command": "orbital.openRepoTerminal",
        "title": "Orbital: Open Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "orbital.setAlias",
        "title": "Orbital: Set Alias",
        "icon": "$(tag)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "orbital.addRepo",
          "when": "view == orbital.repoTree",
          "group": "navigation"
        },
        {
          "command": "orbital.refresh",
          "when": "view == orbital.repoTree",
          "group": "navigation"
        },
        {
          "command": "orbital.openDashboard",
          "when": "view == orbital.repoTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "orbital.editNotes",
          "when": "view == orbital.repoTree && viewItem == repo",
          "group": "inline"
        },
        {
          "command": "orbital.openRepoFolder",
          "when": "view == orbital.repoTree && viewItem == repo",
          "group": "navigation"
        },
        {
          "command": "orbital.openRepoTerminal",
          "when": "view == orbital.repoTree && viewItem == repo",
          "group": "navigation"
        },
        {
          "command": "orbital.setAlias",
          "when": "view == orbital.repoTree && viewItem == repo"
        },
        {
          "command": "orbital.removeRepo",
          "when": "view == orbital.repoTree && viewItem == repo"
        }
      ]
    },
    "configuration": {
      "title": "Orbital",
      "properties": {
        "orbital.pollIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often (in seconds) to poll repos for git status updates."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
